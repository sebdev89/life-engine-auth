# life-engine-auth — copy to .env.local (do not commit .env*) and source before `mvn spring-boot:run`.
# Mirrors life-engine/.env.template minus the agent-runtime gRPC + Dev Agent + Crypto blocks.

# --- deployment (required) ---
# IMPORTANT: this service's LifeengineApplicationEnvironmentPreparedListener fires BEFORE Spring
# loads application.yml, so the `${APP_ENV:local}` default in the YAML does NOT reach the listener.
# You must export BOTH variables below (or one of them and the matching `-Dlifeengine.deployment.env=...`
# JVM arg). The listener only reads `lifeengine.deployment.env`; the YAML reads `APP_ENV`.
APP_ENV=local
LIFEENGINE_DEPLOYMENT_ENV=local
SPRING_PROFILES_ACTIVE=local
# Allowed: local | dev | prod | test

# --- JWT / auth (required for app startup: JWT must be >= 32 UTF-8 bytes) ---
JWT_SECRET=
AUTH_BOOTSTRAP_USER=
AUTH_BOOTSTRAP_PASSWORD=

# Guest exploration API (POST /api/auth/guest). Default in YAML is false.
GUEST_AUTH_ENABLED=false

# --- database (password required when APP_ENV is dev or prod) ---
# Ownership: life-engine-auth owns DB `life_engine_auth` (schema public).
# Create locally before first boot: `PGPASSWORD=life createdb -h localhost -p 5433 -U life life_engine_auth`.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/life_engine_auth
SPRING_DATASOURCE_USERNAME=life
SPRING_DATASOURCE_PASSWORD=
SPRING_R2DBC_URL=r2dbc:postgresql://localhost:5433/life_engine_auth
SPRING_R2DBC_USERNAME=life
SPRING_R2DBC_PASSWORD=
SPRING_FLYWAY_URL=jdbc:postgresql://localhost:5433/life_engine_auth
SPRING_FLYWAY_USER=life
SPRING_FLYWAY_PASSWORD=
FLYWAY_ENABLED=true

# --- password reset (optional; Resend HTTP) ---
PASSWORD_RESET_DEBUG_TOKEN=true
RESEND_API_KEY=
RESEND_FROM=
PASSWORD_RESET_PUBLIC_BO_URL=http://localhost:4200

# --- Google sign-in (optional) ---
GOOGLE_LOGIN_CLIENT_ID=
GOOGLE_LOGIN_CLIENT_SECRET=
GOOGLE_LOGIN_REDIRECT_URI=http://localhost:8080/api/auth/google/callback
GOOGLE_LOGIN_BO_RETURN_URL=http://localhost:4200/auth/google/callback

# --- dev seeds (local profile only — never enable in prod) ---
LOCAL_DEV_ADMIN_PASSWORD=admin123456
LOCAL_DEV_E2E_PASSWORD=DevOnly_SmokePass_9x!
LOCAL_DEV_PASSWORD_ROTATION_PASSWORD=DevOnly_RotatePass_9x!
DEV_PASSWORD_RESET_API_KEY=dev-only-reset-key
LOCAL_DEV_REGISTRATION_ENABLED=false

# --- HTTP / CORS (production only — local/dev/test use permissive localhost patterns) ---
LIFEENGINE_HTTP_CORS_ALLOWED_ORIGINS=

# --- server port (default 8081 — avoids collision with the life-engine modulith on :8080) ---
LIFE_ENGINE_AUTH_PORT=8081
